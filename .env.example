# PacketPulse DPI System Environment Variables
# Copy this file to .env and update values as needed

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=raw_packets
KAFKA_TOPIC_PROCESSED=processed_packets
KAFKA_TOPIC_ALERTS=alerts

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# PostgreSQL Configuration
POSTGRES_URL=postgresql+asyncpg://pp:pp_secret@postgres/packetpulse

# API Gateway Configuration
ADMIN_SECRET=change_me
API_KEY=dev_key_12345
HEALTH_PORT=8001

# Packet Service Configuration
INTERFACE=eth0

# Detection Service Configuration
MODEL_PATH=./models

# Service Health Ports
PACKET_SERVICE_HEALTH_PORT=8001
PROCESSING_SERVICE_HEALTH_PORT=8002
DETECTION_SERVICE_HEALTH_PORT=8003

# Vite Frontend Configuration
VITE_API_KEY=dev_key_12345
VITE_API_BASE=https://your-railway-url.railway.app
VITE_WS_BASE=wss://your-railway-url.railway.app
